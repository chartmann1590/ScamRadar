    <string name="perm_notif_listener_title">Live Shield notification access</string>
    <string name="perm_notif_listener_rationale">ScamRadar needs notification access to scan incoming message previews on your phone. Nothing is uploaded — every check runs locally with the same engine you already use. You can choose which apps Shield watches, pause it any time, or turn it off entirely.</string>
    <string name="perm_clipboard_title">Clipboard scan chip</string>
    <string name="perm_clipboard_rationale">When you copy a link or phone number, ScamRadar can offer a one-tap check. Android may show a clipboard message each time we read it — that\'s a system safety feature. You can disable this at any time.</string>
    <string name="perm_post_notifications_rationale">ScamRadar uses notifications to surface scam warnings, trending alerts, and family digests. You can disable any category in Settings.</string>
    <string name="perm_microphone_rationale">Used only for the voicemail and AI-voice scam checks you initiate. Audio never leaves your phone.</string>

